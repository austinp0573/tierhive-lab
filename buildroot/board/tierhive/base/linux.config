# tierhive vps kernel config fragment
# applied on top of arch/x86/configs/x86_64_defconfig for linux 6.6.x
#
# this file only documents changes from the upstream x86_64 baseline
# anything not listed here inherits its x86_64_defconfig default
#
# if the hardware is not present in a kvm vps, then no driver included for it

# kvm guest/paravirtualization
# paravirt ops reduce vmexits for common operations when running under kvm
# kvm_clock replaces the tsc-based clock with a paravirt clock source,
# which avoids expensive clocksource queries on every time-related syscall
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_CLOCK=y

# virtio
# all disk and network i/o on a kvm vps goes through virtio.
# legacy pci retained incase tierhave has not migrated to virtio 1.0.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
# virtio_input is a virtual input device; no display or physical input on a vps
# CONFIG_VIRTIO_INPUT is not set

# serial console
# ttyS0 is the most common out-of-band console
# busybox getty in inittab binds to ttyS0
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
# CONFIG_SERIAL_8250_MANY_PORTS is not set

# devtmpfs
# kernel populates /dev automatically at boot; no mdev or udev needed.
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# acpi
# required for graceful shutdown signals from the hypervisor (virsh shutdown)
CONFIG_ACPI=y

# networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y

# netfilter remains because:
# a) overhead at idle is negligible (no rules loaded = fast path through nf_hook)
# b) wireguard and frp derivatives require it
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=m

# tun/tap: required for wireguard (which creates a tun interface)
CONFIG_TUN=y

# modules: kept enabled so derivatives can load additional kernel modules
# without rebuilding. the base image loads no modules at runtime.
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# filesystems
# ext4 only, one filesystem type on one partition.
CONFIG_EXT4_FS=y
# CONFIG_EXT4_FS_POSIX_ACL is not set
# CONFIG_EXT4_FS_SECURITY is not set
# CONFIG_EXT4_DEBUG is not set

# tmpfs for /tmp and /run; proc and sysfs are required
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# no network filesystems
# CONFIG_NFS_FS is not set
# CONFIG_NFSD is not set
# CONFIG_CIFS is not set
# CONFIG_9P_FS is not set

# no additional local filesystems
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_JFS_FS is not set
# CONFIG_REISERFS_FS is not set
# CONFIG_F2FS_FS is not set
# CONFIG_GFS2_FS is not set
# CONFIG_NILFS2_FS is not set
# CONFIG_FUSE_FS is not set

# no fat/vfat
# the grub bios boot partition is handled by grub, not the kernel
# CONFIG_FAT_FS is not set
# CONFIG_VFAT_FS is not set
# CONFIG_MSDOS_FS is not set
# CONFIG_NTFS_FS is not set

# sound
# no audio hardware in a vps
# CONFIG_SOUND is not set
# CONFIG_SND is not set

# bluetooth
# CONFIG_BT is not set

# wireless
# CONFIG_WIRELESS is not set
# CONFIG_CFG80211 is not set
# CONFIG_MAC80211 is not set
# CONFIG_RFKILL is not set

# graphics / display
# there is no display
# all console access is via ttyS0
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_BACKLIGHT_LCD_SUPPORT is not set
# CONFIG_VGA_CONSOLE is not set
# CONFIG_FRAMEBUFFER_CONSOLE is not set
# CONFIG_LOGO is not set

# usb
# no usb hardware
# CONFIG_USB_SUPPORT is not set

# input devices
# the serial console does not require the input subsystem, hid, or ps/2
# CONFIG_INPUT is not set
# CONFIG_HID is not set
# CONFIG_HID_SUPPORT is not set
# CONFIG_SERIO is not set

# hardware not present in a vps
# CONFIG_PCCARD is not set
# CONFIG_PCMCIA is not set
# CONFIG_FIREWIRE is not set
# CONFIG_INFINIBAND is not set
# CONFIG_ISDN is not set
# CONFIG_ATM is not set
# CONFIG_MEDIA_SUPPORT is not set

# staging drivers
# staging drivers are development-quality
# not a production image
# CONFIG_STAGING is not set

# kernel debug / tracing
# disabling ftrace and kgdb frees ~1-2mb of kernel memory at runtime.
# these are not useful on a deployed appliance image.
# CONFIG_KGDB is not set
# CONFIG_FTRACE is not set
# CONFIG_DYNAMIC_FTRACE is not set
