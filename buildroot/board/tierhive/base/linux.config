# kvm/virtio vps kernel config
# used as BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE (not a fragment)
# unlisted options take their kconfig defaults
# most default to n

# ipc and cgroup support
CONFIG_SYSVIPC=y
CONFIG_CGROUPS=y

# loadable module support
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# smp
CONFIG_SMP=y

# kvm guest optimizations
# paravirt reduces vm-exit overhead significantly
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y

# networking
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=y

# netfilter
# allows iptables rules, loaded as modules, zero cost when unused
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=m
CONFIG_NETFILTER_XTABLES=m
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m

# tun/tap - required for wireguard and other vpn tools
CONFIG_TUN=y

# pci bus - required by virtio-pci transport layer
CONFIG_PCI=y

# devtmpfs - kernel populates /dev
# no udev or mdev needed
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# block devices
# virtio-blk is the primary path
# scsi+ata cover providers that use different backends
CONFIG_VIRTIO_BLK=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y
CONFIG_ATA=y
CONFIG_ATA_PIIX=y

# network devices
CONFIG_NETDEVICES=y
CONFIG_VIRTIO_NET=y

# input
CONFIG_INPUT_EVDEV=y

# serial and virtio console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VIRTIO_CONSOLE=y

# virtio rng
CONFIG_HW_RANDOM_VIRTIO=m

# virtio bus
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y

# filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
